	"Modèle de table SQLAlchemy 2.0": {
        "prefix": "alchsqlmodel",
        "body": [
            "from sqlalchemy.orm import Mapped, mapped_column",
            "from sqlalchemy import String, Integer",
            "from .database import Base",
            "",
            "class ${1:User}(Base):",
            "    __tablename__ = \"${2:users}\"",
            "",
            "    id: Mapped[int] = mapped_column(Integer, primary_key=True, autoincrement=True)",
            "    ${3:name}: Mapped[str] = mapped_column(String(${4:50}), nullable=False)",
            "    $0"
        ],
        "description": "Crée un modèle de table standard avec SQLAlchemy 2.0"
    },

	"Configuration Session SQLAlchemy": {
        "prefix": "alchsqlconn",
        "body": [
            "import os",
            "from sqlalchemy import create_engine",
            "from sqlalchemy.orm import sessionmaker",
            "",
            "DATABASE_URL = os.getenv(\"CONNECTION_STRING\")",
            "",
            "engine = create_engine(DATABASE_URL, echo=True)",
            "SessionLocal = sessionmaker(autocommit=False, autoflush=False, bind=engine)",
            "",
            "# Dépendance pour récupérer la session (parfait pour FastAPI)",
            "def get_db():",
            "    db = SessionLocal()",
            "    try:",
            "        yield db",
            "    finally:",
            "        db.close()",
            "$0"
        ],
        "description": "Configure l'engine et la session de base de données pour SQLAlchemy"
    },

