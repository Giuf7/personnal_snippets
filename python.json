            "from ${2:app.models} import ${3:ModelName}",
            "",
            "def ${4:handle_data}(*args, **kwargs):",
            "    db = next(get_db())",
            "    try:",
            "        # Ta logique ici (ex: db.query(${3:ModelName}).all())",
