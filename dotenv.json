    "Configuration .env SQL Server": {
        "prefix": "envsql",
        "body": [
            "SERVER = \"${1:nom_du_serveur}\"",
            "DATABASE = \"${2:nom_de_la_bdd}\"",
            "",
            "CONNECTION_STRING = \"mssql+pyodbc://@SERVER/DATABASE?driver=ODBC+Driver+17+for+SQL+Server&trusted_connection=yes&TrustServerCertificate=yes\""
        ],
        "description": "Génère les variables d'environnement pour une connexion MSSQL avec pyodbc"
    }
